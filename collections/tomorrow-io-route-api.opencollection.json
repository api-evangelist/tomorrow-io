{
  "opencollection": "1.0.0",
  "info": {
    "name": "Tomorrow.io Weather on Routes API",
    "version": "4.0"
  },
  "request": {
    "auth": {
      "type": "apikey",
      "key": "apikey",
      "value": "{{apikey}}",
      "placement": "query"
    }
  },
  "items": [
    {
      "info": {
        "name": "Route",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "Retrieve Weather Along Route",
            "type": "http"
          },
          "http": {
            "method": "POST",
            "url": "https://api.tomorrow.io/v4/route",
            "params": [
              {
                "name": "apikey",
                "value": "",
                "type": "query"
              }
            ],
            "body": {
              "type": "json",
              "data": "{}"
            }
          },
          "docs": "Submit a polyline of waypoints with arrival times and receive weather data\nlayers at each waypoint at its predicted arrival time.\n"
        }
      ]
    }
  ],
  "bundled": true
}