          "name": "Retrieve a Weather Map Tile",
          "request": {
            "name": "Retrieve a Weather Map Tile",
            "description": {
              "content": "Retrieve a 256x256 PNG tile rendering the requested data layer at the given\nXYZ Web Mercator address and time. Supports past, current, and forecast\ntime references via the ``timeFormat`` path parameter.\n",
              "type": "text/plain"
            },
            "url": {
              "path": [
                "map",
                "tile",
                ":zoom",
                ":x",
                ":y",
                ":field",
                ":timeFormat"
              ],
              "host": [
                "{{baseUrl}}"
              ],
              "query": [
                {
                  "disabled": false,
                  "key": "apikey",
                  "value": "<string>",
                  "description": "(Required) "
                }
              ],
              "variable": [
                {
                  "disabled": false,
                  "type": "any",
                  "value": "<integer>",
                  "key": "zoom",
                  "description": "(Required) "
                },
                {
                  "disabled": false,
                  "type": "any",
                  "value": "<integer>",
                  "key": "x",
                  "description": "(Required) "
                },
                {
                  "disabled": false,
                  "type": "any",
                  "value": "<integer>",
                  "key": "y",
                  "description": "(Required) "
                },
                {
                  "disabled": false,
                  "type": "any",
                  "value": "<string>",
                  "key": "field",
                  "description": "(Required) Data layer field (e.g. precipitationIntensity, temperature, windSpeed, cloudCover)."
                },
                {
                  "disabled": false,
                  "type": "any",
                  "value": "<string>",
                  "key": "timeFormat",
                  "description": "(Required) ISO-8601 timestamp or 'now'."
                }
              ]
            },
            "header": [
