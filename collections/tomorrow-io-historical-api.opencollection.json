{
  "opencollection": "1.0.0",
  "info": {
    "name": "Tomorrow.io Historical Weather API",
    "version": "4.0"
  },
  "request": {
    "auth": {
      "type": "apikey",
      "key": "apikey",
      "value": "{{apikey}}",
      "placement": "query"
    }
  },
  "items": [
    {
      "info": {
        "name": "Historical",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "Retrieve Historical Timeline",
            "type": "http"
          },
          "http": {
            "method": "POST",
            "url": "https://api.tomorrow.io/v4/historical",
            "params": [
              {
                "name": "apikey",
                "value": "",
                "type": "query"
              }
            ],
            "body": {
              "type": "json",
              "data": "{}"
            }
          },
          "docs": "Retrieve a historical weather timeline for a point, polygon, or polyline\nacross a given start and end time window. Supports the full field catalog\nand minute, hour, and day timesteps depending on plan tier.\n"
        },
        {
          "info": {
            "name": "Get Climate Normals",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://api.tomorrow.io/v4/historical/climate/normals",
            "params": [
              {
                "name": "location",
                "value": "",
                "type": "query"
              },
              {
                "name": "fields",
                "value": "",
                "type": "query"
              },
              {
                "name": "apikey",
                "value": "",
                "type": "query"
              }
            ]
          },
          "docs": "Retrieve monthly climate normals (long-term averages and percentiles) for a\ngiven point. Useful for benchmarking current conditions against typical\nconditions for the location and season.\n"
        }
      ]
    }
  ],
  "bundled": true
}